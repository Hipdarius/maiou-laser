# ─── Lumion Environment Variables ────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.

# Supabase (required for Vercel deployment)
# Get these from: supabase.com → Dashboard → Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# Hardware API key (optional — when set, ESP32 must send X-Hardware-Key header)
# HARDWARE_API_KEY=your-secret-hardware-key
